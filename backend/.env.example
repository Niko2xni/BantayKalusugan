# Neon PostgreSQL Connection String
# Replace this entire string with the one provided by Neon in their dashboard
# Make sure it ends with ?sslmode=require
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD_HERE@ep-cool-cloud-123456.us-east-2.aws.neon.tech/neondb?sslmode=require

# JWT Secret Key (generate a random secure string for production)
JWT_SECRET_KEY=change-me-in-production

# Azure Storage for Document OCR Paper Trail
AZURE_STORAGE_CONNECTION_STRING="DefaultEndpointsProtocol=https;AccountName=YOUR_ACCOUNT;AccountKey=YOUR_KEY;EndpointSuffix=core.windows.net"
AZURE_STORAGE_CONTAINER_NAME="documents"

# Azure AI Document Intelligence (OCR)
AZURE_OCR_ENDPOINT="https://YOUR_RESOURCE.cognitiveservices.azure.com/"
AZURE_OCR_KEY="YOUR_OCR_KEY"

# SMS API PH
SMS_API_KEY="YOUR_API_KEY"
